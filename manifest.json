{
  "manifest_version": 3,
  "name": "Spotify Floating Lyrics",
  "version": "1.1",
  "description": "A premium floating lyrics overlay for Spotify Web Player.",
  "permissions": ["storage"],
  "host_permissions": ["https://open.spotify.com/*"],
  "content_scripts": [
    {
      "matches": ["https://open.spotify.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Spotify Floating Player",
    "default_icon": "logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["placeholder.png", "styles.css", "logo.png"],
      "matches": ["*://open.spotify.com/*"]
    }
  ],
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  }
}
